# Neo4j connection settings
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme        # CHANGE THIS before running docker compose
NEO4J_DATABASE=neo4j

# Extractor settings
EXTRACTOR_TYPE=simple          # "simple" (heuristic) or "llm"

# LLM settings (only needed when EXTRACTOR_TYPE=llm)
LLM_PROVIDER=anthropic         # "anthropic" or "openai"
LLM_MODEL=                     # Leave blank for provider default
LLM_API_KEY=                   # Your API key (NEVER commit this)

# Schema constraints for LLM extraction
ENTITY_TYPES=Person,Organization,Location,Technology,Concept
RELATIONSHIP_TYPES=WORKS_FOR,LOCATED_IN,RELATED_TO,USES,PART_OF
